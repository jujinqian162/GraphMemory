{
  "dataset": "hotpotqa",
  "default_profile": "full",
  "enable_ablation": false,
  "defaults": {
    "dense_encoder": "models/intfloat-e5-base-v2",
    "passage_prefix": "passage: ",
    "query_prefix": "query: ",
    "seed": 13,
    "top_k": 10
  },
  "graph": {
    "max_bridge_edges": 50,
    "max_entity_neighbors": 10,
    "max_query_overlap": 20,
    "use_spacy": false
  },
  "methods": [
    "bm25",
    "dense",
    "memory_stream"
  ],
  "profiles": {
    "full": {
      "dev_examples": 1000,
      "test_examples": 1000,
      "train_examples": 1000
    },
    "quick": {
      "dev_examples": 100,
      "test_examples": 100,
      "train_examples": 100
    },
    "smoke": {
      "dev_examples": 1,
      "test_examples": 1,
      "train_examples": 1
    }
  },
  "raw": {
    "dev": "data/hotpotqa/raw/dev.json",
    "train": "data/hotpotqa/raw/train.json"
  },
  "recipe": "hotpotqa_memory_stream",
  "search_spaces": {
    "memory_stream": "configs/search_spaces/memory_stream.json"
  },
  "split_offsets": {
    "dev": 0,
    "test": 0,
    "train": 0
  },
  "split_sources": {
    "dev": "importance",
    "test": "importance",
    "train": "train"
  },
  "task": "evidence_retrieval"
}
